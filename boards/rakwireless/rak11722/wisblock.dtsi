#include <zephyr/dt-bindings/gpio/wisblock-io-connector.h>
#include <zephyr/dt-bindings/adc/wisblock-adc.h>
#include <zephyr/dt-bindings/pwm/wisblock-pwm.h>

/ {
	wisblock_io: wisblock_io {
		compatible = "wisblock-io-connector";
		#gpio-cells = <2>;
		gpio-map-mask = <0xffffffff 0xffffffc0>;
		gpio-map-pass-thru = <0 0x3f>;
		gpio-map =
			<WISBLOCK_IO_TXD0	0	&gpio32_63	7	0>,
			<WISBLOCK_IO_RXD0	0	&gpio32_63	8	0>,
			<WISBLOCK_IO_LED1	0	&gpio32_63	12	0>,
			<WISBLOCK_IO_LED2	0	&gpio32_63	13	0>,
			<WISBLOCK_IO_I2C1_SDA	0	&gpio0_31	25	0>,
			<WISBLOCK_IO_I2C1_SCL	0	&gpio0_31	27	0>,
			<WISBLOCK_IO_AIN0	0	&gpio0_31	13	0>,
			<WISBLOCK_IO_AIN1	0	&gpio32_63	1	0>,
			<WISBLOCK_IO_IO7	0	&gpio32_63	0	0>,
			<WISBLOCK_IO_SPI_CS	0	&gpio0_31	1	0>,
			<WISBLOCK_IO_SPI_CLK	0	&gpio0_31	5	0>,
			<WISBLOCK_IO_SPI_MISO	0	&gpio0_31	6	0>,
			<WISBLOCK_IO_SPI_MOSI	0	&gpio0_31	7	0>,
			<WISBLOCK_IO_IO1	0	&gpio32_63	6	0>,
			<WISBLOCK_IO_IO2	0	&gpio0_31	4	0>,
			<WISBLOCK_IO_IO3	0	&gpio32_63	5	0>,
			<WISBLOCK_IO_IO4	0	&gpio0_31	31	0>,
			<WISBLOCK_IO_TXD1	0	&gpio32_63	10	0>,
			<WISBLOCK_IO_RXD1	0	&gpio32_63	11	0>,
			<WISBLOCK_IO_IO5	0	&gpio0_31	12	0>,
			<WISBLOCK_IO_IO6	0	&gpio32_63	4	0>;

		has-io7;
	};

		wisblock_adc: wisblock_adc {
			compatible = "wisblock-adc";
			#io-channel-cells = <1>;
			io-channel-map =
				<WISBLOCK_ADC_AIN0	&adc0	8>,
				<WISBLOCK_ADC_AIN1	&adc0	5>,
				<WISBLOCK_ADC_IO4	&adc0	3>;
		};

	wisblock_pwm: wisblock_pwm {
		compatible = "wisblock-pwm";
		#pwm-cells = <3>;
		pwm-map-mask = <0xffffffff 0x0 0x0>;
		pwm-map-pass-thru = <0x0 0xffffffff 0xffffffff>;

		pwm-map =
			<WISBLOCK_PWM_LED1	0	0	&pwm5	0	0	0>,
			<WISBLOCK_PWM_IO3	0	0	&pwm7	0	0	0>,
			<WISBLOCK_PWM_IO5	0	0	&pwm0	0	0	0>;
	};
};

wisblock_console: &uart0 {};

wisblock_uart0: &uart0 {};
wisblock_uart1: &uart1 {};
wisblock_i2c1: &i2c2 {};
wisblock_spi: &spi0 {};
