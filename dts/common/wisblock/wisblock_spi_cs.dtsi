/*
 * Rebuild WISBLOCK_SPI_CS_GPIOS from all occupied slots.
 *
 * Runs on every include so the macro always reflects the accumulated state
 * at that textual position in the concatenated overlay file. DTS
 * last-writer-wins means the final shield's cs-gpios assignment contains
 * the complete array for all shields combined.
 */
#undef WISBLOCK_SPI_CS_GPIOS
#if   WISBLOCK_SPI_CS_COUNT == 1
# define WISBLOCK_SPI_CS_GPIOS \
	_WISBLOCK_SPI_CS_GPIOS_0
#elif WISBLOCK_SPI_CS_COUNT == 2
# define WISBLOCK_SPI_CS_GPIOS \
	_WISBLOCK_SPI_CS_GPIOS_0, \
	_WISBLOCK_SPI_CS_GPIOS_1
#elif WISBLOCK_SPI_CS_COUNT == 3
# define WISBLOCK_SPI_CS_GPIOS \
	_WISBLOCK_SPI_CS_GPIOS_0, \
	_WISBLOCK_SPI_CS_GPIOS_1, \
	_WISBLOCK_SPI_CS_GPIOS_2
#elif WISBLOCK_SPI_CS_COUNT == 4
# define WISBLOCK_SPI_CS_GPIOS \
	_WISBLOCK_SPI_CS_GPIOS_0, \
	_WISBLOCK_SPI_CS_GPIOS_1, \
	_WISBLOCK_SPI_CS_GPIOS_2, \
	_WISBLOCK_SPI_CS_GPIOS_3
#elif WISBLOCK_SPI_CS_COUNT == 5
# define WISBLOCK_SPI_CS_GPIOS \
	_WISBLOCK_SPI_CS_GPIOS_0, \
	_WISBLOCK_SPI_CS_GPIOS_1, \
	_WISBLOCK_SPI_CS_GPIOS_2, \
	_WISBLOCK_SPI_CS_GPIOS_3, \
	_WISBLOCK_SPI_CS_GPIOS_4
#elif WISBLOCK_SPI_CS_COUNT == 6
# define WISBLOCK_SPI_CS_GPIOS \
	_WISBLOCK_SPI_CS_GPIOS_0, \
	_WISBLOCK_SPI_CS_GPIOS_1, \
	_WISBLOCK_SPI_CS_GPIOS_2, \
	_WISBLOCK_SPI_CS_GPIOS_3, \
	_WISBLOCK_SPI_CS_GPIOS_4, \
	_WISBLOCK_SPI_CS_GPIOS_5
#elif WISBLOCK_SPI_CS_COUNT == 7
# define WISBLOCK_SPI_CS_GPIOS \
	_WISBLOCK_SPI_CS_GPIOS_0, \
	_WISBLOCK_SPI_CS_GPIOS_1, \
	_WISBLOCK_SPI_CS_GPIOS_2, \
	_WISBLOCK_SPI_CS_GPIOS_3, \
	_WISBLOCK_SPI_CS_GPIOS_4, \
	_WISBLOCK_SPI_CS_GPIOS_5, \
	_WISBLOCK_SPI_CS_GPIOS_6
#endif /* WISBLOCK_SPI_CS_COUNT */