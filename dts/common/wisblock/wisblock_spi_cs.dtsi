/**
 * @file
 * @brief SPI chip-select GPIO phandle-array accumulator for WisBlock shields.
 */

/*
 * Usage
 * -----
 * Include this file once per SPI CS signal a shield needs on wisblock_spi.
 * Before each include, define exactly one WISBLOCK_SPI_USE_* activation macro
 * together with its matching _FLAGS macro, then extend wisblock_spi:
 *
 *   #define WISBLOCK_SPI_USE_IO1
 *   #define WISBLOCK_SPI_IO1_FLAGS  (GPIO_ACTIVE_LOW)
 *   #include <wisblock/wisblock_spi_cs.dtsi>
 *
 *   &wisblock_spi {
 *       cs-gpios = WISBLOCK_SPI_CS_GPIOS;
 *       my_dev: my_dev@WISBLOCK_SPI_IO1_IDX {
 *           reg = <WISBLOCK_SPI_IO1_REG>;
 *       };
 *   };
 *
 * Direct IO-pin signals
 * ---------------------
 *   WISBLOCK_SPI_USE_IO1    + WISBLOCK_SPI_IO1_FLAGS    IO1 as CS
 *   WISBLOCK_SPI_USE_IO2    + WISBLOCK_SPI_IO2_FLAGS    IO2 as CS
 *   WISBLOCK_SPI_USE_IO3    + WISBLOCK_SPI_IO3_FLAGS    IO3 as CS
 *   WISBLOCK_SPI_USE_IO4    + WISBLOCK_SPI_IO4_FLAGS    IO4 as CS
 *   WISBLOCK_SPI_USE_IO5    + WISBLOCK_SPI_IO5_FLAGS    IO5 as CS
 *   WISBLOCK_SPI_USE_IO6    + WISBLOCK_SPI_IO6_FLAGS    IO6 as CS
 *   WISBLOCK_SPI_USE_SPI_CS + WISBLOCK_SPI_CS_FLAGS     dedicated SPI CS pin
 *
 * Slot-alias signals (translated to wisblock_io phandle internally)
 * -----------------------------------------------------------------
 *   Slot A: GPIO1 -> IO2, GPIO2 -> IO1
 *   Slot B: GPIO1 -> IO1, GPIO2 -> IO2
 *   Slot C: GPIO1 -> IO4, GPIO2 -> IO3
 *   Slot D: GPIO1 -> IO6, GPIO2 -> IO5
 *   Slot E: GPIO1 -> IO3, GPIO2 -> IO4
 *   Slot F: GPIO1 -> IO5, GPIO2 -> IO6
 *
 *   WISBLOCK_SPI_USE_SLOTA_GPIO1 + WISBLOCK_SPI_SLOTA_GPIO1_FLAGS
 *   WISBLOCK_SPI_USE_SLOTA_GPIO2 + WISBLOCK_SPI_SLOTA_GPIO2_FLAGS
 *   (analogously for slots B through F)
 *
 * How it works
 * ------------
 * Zephyr concatenates all active shield overlays into one translation unit
 * and runs a single C preprocessor pass. This file maintains a running
 * counter WISBLOCK_SPI_CS_COUNT and per-slot cache macros
 * _WISBLOCK_SPI_CS_GPIOS_N. On every include it:
 *
 *   1. Checks whether the requested signal is already registered via its
 *      physical-pin IDX guard, preventing accidental double-allocation.
 *   2. Assigns the next available slot index to the signal.
 *   3. Stores the phandle cell in _WISBLOCK_SPI_CS_GPIOS_N using &wisblock_io
 *      directly so slot-aliased signals resolve without double indirection.
 *   4. Rebuilds WISBLOCK_SPI_CS_GPIOS from all occupied slots.
 *
 * DTS property assignment uses last-writer-wins semantics. The cs-gpios line
 * in the last shield overlay always carries the complete array that covers
 * all earlier shields.
 *
 * If two shields request the same physical IO pin, the second registration
 * block is silently skipped (the IDX guard is already defined). The shield's
 * @<IDX> node-address macro will then be undefined, producing a deterministic
 * DTC error that clearly identifies the conflict.
 *
 * Maximum supported CS entries: 7 (SPI_CS, IO1-IO6).
 */

#ifndef WISBLOCK_SPI_CS_ACCUMULATOR_DEPS
#define WISBLOCK_SPI_CS_ACCUMULATOR_DEPS
#include <zephyr/dt-bindings/gpio/wisblock-io-connector.h>
#endif

/* Running counter -- persists across includes in a single cpp pass */
#ifndef WISBLOCK_SPI_CS_COUNT
# define WISBLOCK_SPI_CS_COUNT 0
#endif

/* IO1 */
#if defined(WISBLOCK_SPI_USE_IO1) && !defined(WISBLOCK_SPI_IO1_IDX)
# if   WISBLOCK_SPI_CS_COUNT == 0
#  define WISBLOCK_SPI_IO1_IDX 0
#  define WISBLOCK_SPI_IO1_REG 0x0
#  define _WISBLOCK_SPI_CS_GPIOS_0 <&wisblock_io WISBLOCK_IO_IO1 WISBLOCK_SPI_IO1_FLAGS>
#  undef  WISBLOCK_SPI_CS_COUNT
#  define WISBLOCK_SPI_CS_COUNT 1
# elif WISBLOCK_SPI_CS_COUNT == 1
#  define WISBLOCK_SPI_IO1_IDX 1
#  define WISBLOCK_SPI_IO1_REG 0x1
#  define _WISBLOCK_SPI_CS_GPIOS_1 <&wisblock_io WISBLOCK_IO_IO1 WISBLOCK_SPI_IO1_FLAGS>
#  undef  WISBLOCK_SPI_CS_COUNT
#  define WISBLOCK_SPI_CS_COUNT 2
# elif WISBLOCK_SPI_CS_COUNT == 2
#  define WISBLOCK_SPI_IO1_IDX 2
#  define WISBLOCK_SPI_IO1_REG 0x2
#  define _WISBLOCK_SPI_CS_GPIOS_2 <&wisblock_io WISBLOCK_IO_IO1 WISBLOCK_SPI_IO1_FLAGS>
#  undef  WISBLOCK_SPI_CS_COUNT
#  define WISBLOCK_SPI_CS_COUNT 3
# elif WISBLOCK_SPI_CS_COUNT == 3
#  define WISBLOCK_SPI_IO1_IDX 3
#  define WISBLOCK_SPI_IO1_REG 0x3
#  define _WISBLOCK_SPI_CS_GPIOS_3 <&wisblock_io WISBLOCK_IO_IO1 WISBLOCK_SPI_IO1_FLAGS>
#  undef  WISBLOCK_SPI_CS_COUNT
#  define WISBLOCK_SPI_CS_COUNT 4
# elif WISBLOCK_SPI_CS_COUNT == 4
#  define WISBLOCK_SPI_IO1_IDX 4
#  define WISBLOCK_SPI_IO1_REG 0x4
#  define _WISBLOCK_SPI_CS_GPIOS_4 <&wisblock_io WISBLOCK_IO_IO1 WISBLOCK_SPI_IO1_FLAGS>
#  undef  WISBLOCK_SPI_CS_COUNT
#  define WISBLOCK_SPI_CS_COUNT 5
# elif WISBLOCK_SPI_CS_COUNT == 5
#  define WISBLOCK_SPI_IO1_IDX 5
#  define WISBLOCK_SPI_IO1_REG 0x5
#  define _WISBLOCK_SPI_CS_GPIOS_5 <&wisblock_io WISBLOCK_IO_IO1 WISBLOCK_SPI_IO1_FLAGS>
#  undef  WISBLOCK_SPI_CS_COUNT
#  define WISBLOCK_SPI_CS_COUNT 6
# elif WISBLOCK_SPI_CS_COUNT == 6
#  define WISBLOCK_SPI_IO1_IDX 6
#  define WISBLOCK_SPI_IO1_REG 0x6
#  define _WISBLOCK_SPI_CS_GPIOS_6 <&wisblock_io WISBLOCK_IO_IO1 WISBLOCK_SPI_IO1_FLAGS>
#  undef  WISBLOCK_SPI_CS_COUNT
#  define WISBLOCK_SPI_CS_COUNT 7
# endif
#endif /* IO1 */

