/*
 * Slot GPIO alias blocks
 * ----------------------
 *
 * Each alias block checks its physical-pin IDX guard before registering.
 * The alias-specific IDX/REG macros are set alongside the physical-pin
 * guard so the shield can reference @WISBLOCK_SPI_SLOT*_GPIO*_IDX.
 */

/* Slot A GPIO1 -> IO2 */
#if defined(WISBLOCK_SPI_USE_SLOTA_GPIO1) && !defined(WISBLOCK_SPI_SLOTA_GPIO1_IDX)
# ifndef WISBLOCK_SPI_IO2_IDX
#  if   WISBLOCK_SPI_CS_COUNT == 0
#   define WISBLOCK_SPI_IO2_IDX          0
#   define WISBLOCK_SPI_SLOTA_GPIO1_IDX  0
#   define WISBLOCK_SPI_SLOTA_GPIO1_REG  0x0
#   define _WISBLOCK_SPI_CS_GPIOS_0 <&wisblock_io WISBLOCK_IO_IO2 WISBLOCK_SPI_SLOTA_GPIO1_FLAGS>
#   undef  WISBLOCK_SPI_CS_COUNT
#   define WISBLOCK_SPI_CS_COUNT 1
#  elif WISBLOCK_SPI_CS_COUNT == 1
#   define WISBLOCK_SPI_IO2_IDX          1
#   define WISBLOCK_SPI_SLOTA_GPIO1_IDX  1
#   define WISBLOCK_SPI_SLOTA_GPIO1_REG  0x1
#   define _WISBLOCK_SPI_CS_GPIOS_1 <&wisblock_io WISBLOCK_IO_IO2 WISBLOCK_SPI_SLOTA_GPIO1_FLAGS>
#   undef  WISBLOCK_SPI_CS_COUNT
